# Machine-specific VS Code settings (absolute paths to toolchain)
.vscode/settings.json

# CMake build output
cmake_gcc/build/

# Machine-specific generated CMake files (regenerated by Simplicity Studio)
cmake_gcc/PIR_EFR32.cmake
cmake_gcc/PIR_EFR32_project.cmake
cmake_gcc/CMakePresets.json
cmake_gcc/toolchain.cmake

# Simplicity Studio generated/autogen files
autogen/

# SLC / SLT cache
.slc_cache/
.slt_cache/

# Compiled object files
*.o
*.obj
*.elf
*.hex
*.bin
*.map

# IDE / OS junk
*.log
Thumbs.db
.DS_Store

# Python cache (if used for prototyping scripts)
__pycache__/
*.pyc